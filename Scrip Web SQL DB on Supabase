  s.nombre as nombre_sucursal,
  c.id as id_caja,
  c.codigo as codigo_caja,
  c.numero_ventanilla,
  ec.codigo as estado_caja,
  u.nombre_usuario as cajero_actual,
  (u.nombre || ' '::text) || u.apellido as nombre_completo_cajero,
  m.codigo_iso as moneda,
  sc.saldo_actual,
  sc.saldo_reservado,
  sc.saldo_actual - sc.saldo_reservado as saldo_disponible,
  sc.ultima_actualizacion
from
  suc_cajas c
  join suc_sucursales s on s.id = c.id_sucursal
  join cfg_estados_caja ec on ec.id = c.id_estado_caja
  left join tes_saldos_caja sc on sc.id_caja = c.id
  left join cfg_monedas m on m.id = sc.id_moneda
  left join suc_asignaciones_caja a on a.id_caja = c.id
  and a.asignacion_activa = true
  left join usr_usuarios u on u.id = a.id_usuario
where
  c.activo = true;


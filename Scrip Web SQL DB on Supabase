CREATE OR REPLACE FUNCTION fn_registrar_auditoria(
  p_id_usuario       BIGINT,
  p_entidad_afectada VARCHAR,
  p_id_registro      BIGINT,
  p_accion           VARCHAR,
  p_datos_anteriores JSONB   DEFAULT NULL,
  p_datos_nuevos     JSONB   DEFAULT NULL,
  p_id_sesion        BIGINT  DEFAULT NULL,
  p_ip_origen        INET    DEFAULT NULL,
  p_endpoint_api     TEXT    DEFAULT NULL
)
RETURNS VOID
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
BEGIN

  -- Validar acción contra el CHECK real de aud_log_operaciones
  IF p_accion NOT IN ('INSERCION', 'ACTUALIZACION', 'ELIMINACION', 'LECTURA_SENSIBLE') THEN
    RAISE EXCEPTION
      '[fn_registrar_auditoria] Acción inválida: %. Valores permitidos: INSERCION, ACTUALIZACION, ELIMINACION, LECTURA_SENSIBLE',
      p_accion;
  END IF;

  IF p_id_usuario IS NULL THEN
    RAISE EXCEPTION '[fn_registrar_auditoria] p_id_usuario no puede ser NULL';
  END IF;

  IF p_entidad_afectada IS NULL OR trim(p_entidad_afectada) = '' THEN
    RAISE EXCEPTION '[fn_registrar_auditoria] p_entidad_afectada no puede ser NULL o vacío';
  END IF;

  IF p_id_registro IS NULL THEN
    RAISE EXCEPTION '[fn_registrar_auditoria] p_id_registro no puede ser NULL';
  END IF;

  INSERT INTO aud_log_operaciones (
    id_usuario,
    id_sesion,
    entidad_afectada,
    id_registro_afectado,
    accion,
    datos_anteriores,
    datos_nuevos,
    ip_origen,
    endpoint_api
  ) VALUES (
    p_id_usuario,
    p_id_sesion,
    p_entidad_afectada,
    p_id_registro,
    p_accion,
    p_datos_anteriores,
    p_datos_nuevos,
    p_ip_origen,
    p_endpoint_api
  );

EXCEPTION
  WHEN OTHERS THEN
    RAISE EXCEPTION
      '[fn_registrar_auditoria] Error al registrar auditoría en % (id: %): %',
      p_entidad_afectada, p_id_registro, SQLERRM;
END;
$$;


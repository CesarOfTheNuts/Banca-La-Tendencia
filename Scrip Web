create view public.v_alertas_activas as
select
  a.id,
  a.tipo_alerta,
  a.nivel_criticidad,
  a.mensaje,
  s.nombre as nombre_sucursal,
  c.codigo as codigo_caja,
  t.numero_referencia as referencia_transaccion,
  a.creado_en,
  EXTRACT(
    epoch
    from
      CURRENT_TIMESTAMP - a.creado_en
  ) / 60::numeric as minutos_abierta
from
  mov_alertas a
  left join suc_sucursales s on s.id = a.id_sucursal
  left join suc_cajas c on c.id = a.id_caja
  left join mov_transacciones t on t.id = a.id_transaccion
where
  a.resuelta = false
order by
  (
    case a.nivel_criticidad
      when 'ROJO'::text then 1
      when 'AMARILLO'::text then 2
      when 'VERDE'::text then 3
      else null::integer
    end
  ),
  a.creado_en;

create view public.v_kpi_diario_sucursal as
select
  s.id as id_sucursal,
  s.codigo as codigo_sucursal,
  s.nombre as nombre_sucursal,
  m.codigo_iso as moneda,
  COALESCE(ss.saldo_total, 0::numeric) as saldo_total_actual,
  count(t.id) as num_transacciones,
  COALESCE(
    sum(t.monto) filter (
      where
        tt.codigo::text = any (
          array[
            'DEP'::character varying,
            'REM_I'::character varying,
            'RPLN'::character varying
          ]::text[]
        )
    ),
    0::numeric
  ) as total_entradas,
  COALESCE(
    sum(t.monto) filter (
      where
        tt.codigo::text = any (
          array[
            'RET'::character varying,
            'REM_O'::character varying
          ]::text[]
        )
    ),
    0::numeric
  ) as total_salidas,
  count(t.id) filter (
    where
      t.requiere_aprobacion
      and et.codigo::text = 'PENDIENTE'::text
  ) as aprobaciones_pendientes,
  CURRENT_DATE as fecha_reporte
from
  suc_sucursales s
  cross join cfg_monedas m
  left join mov_transacciones t on t.id_sucursal_origen = s.id
  and t.fecha_valor = CURRENT_DATE
  and t.activo = true
  and t.id_moneda = m.id
  left join cfg_tipos_transaccion tt on tt.id = t.id_tipo_transaccion
  left join cfg_estados_transaccion et on et.id = t.id_estado
  left join tes_saldos_sucursal ss on ss.id_sucursal = s.id
  and ss.id_moneda = m.id
where
  s.activo = true
  and m.activo = true
group by
  s.id,
  s.codigo,
  s.nombre,
  m.codigo_iso,
  ss.saldo_total;

create view public.v_saldo_actual_cajas as
select
  s.id as id_sucursal,
  s.codigo as codigo_sucursal,
  s.nombre as nombre_sucursal,
  c.id as id_caja,
  c.codigo as codigo_caja,
  c.numero_ventanilla,
  ec.codigo as estado_caja,
  u.nombre_usuario as cajero_actual,
  (u.nombre || ' '::text) || u.apellido as nombre_completo_cajero,
  m.codigo_iso as moneda,
  sc.saldo_actual,
  sc.saldo_reservado,
  sc.saldo_actual - sc.saldo_reservado as saldo_disponible,
  sc.ultima_actualizacion
from
  suc_cajas c
  join suc_sucursales s on s.id = c.id_sucursal
  join cfg_estados_caja ec on ec.id = c.id_estado_caja
  left join tes_saldos_caja sc on sc.id_caja = c.id
  left join cfg_monedas m on m.id = sc.id_moneda
  left join suc_asignaciones_caja a on a.id_caja = c.id
  and a.asignacion_activa = true
  left join usr_usuarios u on u.id = a.id_usuario
where
  c.activo = true;

create view public.v_transacciones_hoy as
select
  t.id,
  t.numero_referencia,
  s.nombre as nombre_sucursal,
  c.codigo as codigo_caja,
  tt.nombre as tipo_transaccion,
  t.tipo_instrumento,
  m.codigo_iso as moneda,
  t.monto,
  t.monto_moneda_base,
  et.nombre as estado,
  t.nombre_cliente,
  u.nombre_usuario as registrado_por,
  t.canal,
  t.creado_en
from
  mov_transacciones t
  join cfg_tipos_transaccion tt on tt.id = t.id_tipo_transaccion
  join cfg_estados_transaccion et on et.id = t.id_estado
  join cfg_monedas m on m.id = t.id_moneda
  left join suc_sucursales s on s.id = t.id_sucursal_origen
  left join suc_sesiones_caja sc on sc.id = t.id_sesion_caja
  left join suc_cajas c on c.id = sc.id_caja
  left join usr_usuarios u on u.id = t.creado_por
where
  t.fecha_valor = CURRENT_DATE
  and t.activo = true;
